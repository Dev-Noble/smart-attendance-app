# SMAS — Environment Variables
# Copy this file to .env.local and fill in your Firebase project values.
# Never commit .env.local to version control.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# BulkSMS Nigeria (optional)
# Set to 'production' to send real SMS, 'sandbox' for testing
VITE_SMS_ENV=sandbox
VITE_SMS_API_TOKEN=your-bulksms-api-token
VITE_SMS_SENDER_ID=SMAS
