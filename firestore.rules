rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isLecturer() {
      return isSignedIn() && getUserData().role == 'lecturer' || isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // System configurations
    match /system/{document=**} {
      allow read: if isSignedIn();
      allow write: if isLecturer();
    }

    // Student directory
    match /students/{docId} {
      // Allow any signed in user to read students
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isLecturer();
    }

    // Attendance sessions
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isLecturer();
      // Allow students to append their studentId + deviceFingerprint only
      allow update: if isLecturer() || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentsPresent', 'deviceFingerprints'])
      );
      allow delete: if isAdmin();
    }

    // Activity logs
    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
//commnts